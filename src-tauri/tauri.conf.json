{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ADBCHelper",
  "version": "0.1.0",
  "identifier": "com.yangxu.adbchelper",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420"
  },
  "app": {
    "windows": [
      {
        "title": "ADBCHelper",
        "width": 1440,
        "height": 920,
        "minWidth": 1080,
        "minHeight": 760,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "category": "DeveloperTool",
    "icon": []
  }
}
